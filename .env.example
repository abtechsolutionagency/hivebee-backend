NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_PREFIX=/api
MONGODB_URI=mongodb://127.0.0.1:27017/join_the_hive
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
JWT_SECRET=replace-this-in-production
JWT_EXPIRES_IN=7d
APP_BASE_URL=http://localhost:4000
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_ELITE=
STRIPE_PRICE_STARTER_HIVE=
STRIPE_PRICE_GROWTH_HIVE=
STRIPE_PRICE_ROYAL_HIVE=
TRIAL_ENABLED=true
TRIAL_DAYS=7
TRIAL_PRIMARY_USER_CAP=500
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000
EMAIL_FROM=no-reply@jointhehive.local

# AWS S3 (picture uploads)
AWS_S3_REGION=eu-west-2
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Google Gen AI (bio helper)
GOOGLE_API_KEY=
GOOGLE_GENAI_MODEL=gemini-2.5-flash
